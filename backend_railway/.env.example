# DezAI Backend Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
DEBUG=false

# File Handling
MAX_FILE_SIZE=104857600  # 100MB in bytes
FILE_RETENTION_HOURS=24
UPLOAD_DIR=uploads
PROCESSED_DIR=processed

# Processing Configuration
MAX_WORKERS=1
USE_GPU=true  # Set to false if no GPU available
MODEL_NAME=htdemucs  # Demucs model to use

# Security (optional)
API_KEY=your-secret-api-key-here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://dezai-audio-analysis.netlify.app

# Railway Specific
RAILWAY_ENVIRONMENT=production
RAILWAY_SERVICE_NAME=dezai-backend

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn-here
DATADOG_API_KEY=your-datadog-api-key-here